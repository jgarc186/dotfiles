#!/usr/bin/env python3
# Requires: atlassian-python-api, PyYAML
#   pacman -S python-atlassian-python-api python-yaml
#   or: pipx install atlassian-python-api && pip install pyyaml
#
# Required env vars:
#   JIRA_URL            e.g. https://yourorg.atlassian.net
#   JIRA_EMAIL          Atlassian account email
#   JIRA_API_TOKEN      API token from id.atlassian.com/manage-profile/security
#   JIRA_PROJECT_KEY    e.g. MYPROJ
#
# Usage:
#   roadmap-to-jira [--repo <path>]
#
# Reads ROAD_MAP.md from the repo root, uses Claude Opus to generate an Epic
# and Stories as JSON, writes debug artifacts to tickets/, pushes to Jira,
# then cleans up on success.

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import unicodedata
from pathlib import Path

import yaml
from atlassian import Jira
from requests.exceptions import HTTPError

# customfield_10011 is the Epic Name field on most Jira Cloud instances.
# To find yours: Jira Settings → Issues → Custom fields → search "Epic Name"
# and note the field ID in the URL.
EPIC_NAME_FIELD = "customfield_10011"

# customfield_10014 is the Epic Link field used by classic (company-managed) projects.
EPIC_LINK_FIELD = "customfield_10014"

MAX_DESCRIPTION_BYTES = 32_000
CLAUDE_TIMEOUT = 300   # seconds
JIRA_TIMEOUT = 30      # seconds

CLAUDE_PROMPT = """You are a Jira backlog generator. Read the roadmap below and output ONLY a single JSON object — no prose before or after it, no markdown fences, just raw JSON.

Shape:
{
  "epic": { "title": "...", "description": "..." },
  "stories": [
    { "title": "...", "description": "..." },
    ...
  ]
}

Rules:
- epic.title: concise name for the Epic (≤ 60 chars)
- epic.description: 2–4 sentence summary of the full initiative
- stories: one Story per major deliverable or feature in the roadmap; aim for 3–10 stories
- story.title: actionable, starts with a verb (≤ 80 chars)
- story.description: 3–6 sentences covering what to build, why, and acceptance criteria
- All values must be plain text (no markdown, no bullet points inside the JSON strings)

Roadmap:
"""


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Convert ROAD_MAP.md to Jira Epic + Stories")
    p.add_argument("--repo", default=None, help="Path to git repo root (default: cwd)")
    return p.parse_args()


def load_config() -> dict:
    required = ["JIRA_URL", "JIRA_EMAIL", "JIRA_API_TOKEN", "JIRA_PROJECT_KEY"]
    missing = [v for v in required if not os.environ.get(v)]
    if missing:
        print(f"Error: missing required env vars: {', '.join(missing)}", file=sys.stderr)
        sys.exit(2)
    config = {v: os.environ[v] for v in required}
    if not config["JIRA_URL"].startswith("https://"):
        print("Error: JIRA_URL must start with https://", file=sys.stderr)
        sys.exit(2)
    return config


def find_roadmap(repo: Path) -> Path:
    if not (repo / ".git").exists():
        print(f"Error: {repo} is not a git repository (.git not found)", file=sys.stderr)
        sys.exit(3)
    roadmap = repo / "ROAD_MAP.md"
    if not roadmap.exists():
        print(f"Error: ROAD_MAP.md not found in {repo}", file=sys.stderr)
        sys.exit(3)
    return roadmap


def _parse_json_output(text: str) -> dict | None:
    """Parse the first JSON object from Claude output, tolerating surrounding prose.

    Uses json.JSONDecoder.raw_decode so braces inside string values don't confuse
    the extractor and trailing text after the closing brace is ignored.
    """
    stripped = text.strip()
    try:
        result = json.loads(stripped)
        if isinstance(result, dict):
            return result
    except json.JSONDecodeError:
        pass
    start = stripped.find("{")
    if start == -1:
        return None
    try:
        obj, _ = json.JSONDecoder().raw_decode(stripped, start)
        if isinstance(obj, dict):
            return obj
    except json.JSONDecodeError:
        pass
    return None


def _make_slug(title: str) -> str:
    """Return an ASCII-safe, path-safe slug; never empty."""
    normalized = unicodedata.normalize("NFKD", title).encode("ascii", errors="ignore").decode()
    slug = re.sub(r"[^a-z0-9]+", "-", normalized.lower()).strip("-")[:40]
    return slug or "untitled"


def _truncate(text: str, label: str) -> str:
    encoded = text.encode()
    if len(encoded) <= MAX_DESCRIPTION_BYTES:
        return text
    print(f"Warning: {label} description truncated to {MAX_DESCRIPTION_BYTES} bytes", file=sys.stderr)
    return encoded[:MAX_DESCRIPTION_BYTES].decode(errors="ignore")


def generate_tickets(roadmap_path: Path, repo: Path) -> tuple[dict, list[dict]]:
    if not shutil.which("claude"):
        print("Error: 'claude' CLI not found on PATH — install Claude Code first", file=sys.stderr)
        sys.exit(4)

    tickets_dir = repo / "tickets"
    if tickets_dir.exists():
        print(
            f"Error: {tickets_dir} already exists from a prior partial run.\n"
            "Inspect it and remove it before re-running.",
            file=sys.stderr,
        )
        sys.exit(4)

    print("Generating tickets via Claude Opus…")
    try:
        result = subprocess.run(
            ["claude", "-p", "--model", "claude-opus-4-7"],
            input=CLAUDE_PROMPT + roadmap_path.read_text(),
            capture_output=True,
            text=True,
            timeout=CLAUDE_TIMEOUT,
        )
    except subprocess.TimeoutExpired:
        print(f"Error: claude timed out after {CLAUDE_TIMEOUT}s", file=sys.stderr)
        sys.exit(4)

    if result.returncode != 0:
        print(f"Error: claude exited {result.returncode}", file=sys.stderr)
        if result.stderr:
            print(result.stderr, file=sys.stderr)
        sys.exit(4)

    data = _parse_json_output(result.stdout)
    if data is None:
        print("Error: claude output contained no parseable JSON object", file=sys.stderr)
        sys.exit(4)

    epic = data.get("epic")
    stories = data.get("stories", [])
    if not isinstance(epic, dict) or not epic.get("title") or not epic.get("description"):
        print("Error: JSON missing valid 'epic' with title and description", file=sys.stderr)
        sys.exit(4)
    if not stories or not isinstance(stories, list):
        print("Error: JSON missing 'stories' list", file=sys.stderr)
        sys.exit(4)
    for i, s in enumerate(stories):
        if not isinstance(s, dict) or not s.get("title") or not s.get("description"):
            print(f"Error: story {i} is not a valid object with title and description", file=sys.stderr)
            sys.exit(4)

    epic["description"] = _truncate(epic["description"], "Epic")
    for story in stories:
        story["description"] = _truncate(story["description"], f"story '{story['title']}'")

    # Write debug artifacts. These are not re-read; push_to_jira uses the in-memory dicts.
    tickets_dir.mkdir(exist_ok=True)
    fm = yaml.dump({"title": epic["title"], "type": "Epic"}, default_flow_style=False).strip()
    (tickets_dir / "epic.md").write_text(f"---\n{fm}\n---\n\n{epic['description']}\n")
    for i, story in enumerate(stories, start=1):
        fm = yaml.dump({"title": story["title"], "type": "Story"}, default_flow_style=False).strip()
        (tickets_dir / f"story-{i:02d}-{_make_slug(story['title'])}.md").write_text(
            f"---\n{fm}\n---\n\n{story['description']}\n"
        )
    print(f"Wrote {1 + len(stories)} ticket files to {tickets_dir}")

    return epic, stories


def _create_epic(jira: Jira, project: str, epic: dict) -> dict:
    # Exits internally on failure — Epic has nothing to roll back, so there is
    # no need to bubble up for the caller to format a rollback message.
    fields = {
        "project": {"key": project},
        "issuetype": {"name": "Epic"},
        "summary": epic["title"],
        "description": epic["description"],
        EPIC_NAME_FIELD: epic["title"],
    }
    try:
        return jira.issue_create(fields=fields)
    except HTTPError as e:
        if e.response is None or e.response.status_code != 400:
            print(f"Error: failed to create Epic: {e}", file=sys.stderr)
            sys.exit(5)
        # Only retry without EPIC_NAME_FIELD if the error body mentions the field —
        # a 400 for bad project key, permissions, etc. should not trigger a retry.
        body = (e.response.text or "").lower()
        if "10011" not in body and "epic name" not in body:
            print(f"Error: failed to create Epic: {e}", file=sys.stderr)
            sys.exit(5)
        fields.pop(EPIC_NAME_FIELD)
        try:
            return jira.issue_create(fields=fields)
        except Exception as e2:
            print(f"Error: failed to create Epic (original: {e}; retry: {e2})", file=sys.stderr)
            sys.exit(5)
    except Exception as e:
        print(f"Error: failed to create Epic: {e}", file=sys.stderr)
        sys.exit(5)


def _create_story(jira: Jira, project: str, epic_key: str, story: dict) -> dict:
    fields = {
        "project": {"key": project},
        "issuetype": {"name": "Story"},
        "summary": story["title"],
        "description": story["description"],
        "parent": {"key": epic_key},
    }
    try:
        return jira.issue_create(fields=fields)
    except HTTPError as e:
        # Fall back to Epic Link only for HTTP 400 (field validation failure on
        # classic/company-managed projects that don't support the parent field).
        if e.response is None or e.response.status_code != 400:
            raise
        fields.pop("parent")
        fields[EPIC_LINK_FIELD] = epic_key
        return jira.issue_create(fields=fields)


def push_to_jira(
    config: dict, epic: dict, stories: list[dict]
) -> tuple[str, list[tuple[str, str]]]:
    jira = Jira(
        url=config["JIRA_URL"],
        username=config["JIRA_EMAIL"],
        password=config["JIRA_API_TOKEN"],
        cloud=True,
        timeout=JIRA_TIMEOUT,
    )
    project = config["JIRA_PROJECT_KEY"]

    print(f"Creating Epic: {epic['title']}")
    epic_issue = _create_epic(jira, project, epic)

    epic_key = epic_issue.get("key") if isinstance(epic_issue, dict) else None
    if not epic_key:
        print(
            f"Error: unexpected Jira response for Epic (Epic may have been created — check Jira): {epic_issue}",
            file=sys.stderr,
        )
        sys.exit(5)
    print(f"  → {epic_key}")

    created: list[tuple[str, str]] = []  # (story_title, jira_key)
    for story in stories:
        print(f"Creating Story: {story['title']}")
        try:
            story_issue = _create_story(jira, project, epic_key, story)
        except Exception as e:
            # Broad catch is intentional: this is the user-facing rollback boundary and
            # must print partial-failure context for ConnectionError, Timeout, etc. too.
            print(f"Error: Jira API failed creating story '{story['title']}': {e}", file=sys.stderr)
            print(f"  Epic created: {epic_key}", file=sys.stderr)
            if created:
                print("  Stories already created (roll back manually):", file=sys.stderr)
                for title, key in created:
                    print(f"    {key}  {title}", file=sys.stderr)
            sys.exit(5)

        key = story_issue.get("key") if isinstance(story_issue, dict) else None
        if not key:
            print(f"Error: unexpected Jira response for Story: {story_issue}", file=sys.stderr)
            sys.exit(5)
        created.append((story["title"], key))
        print(f"  → {key}")

    return epic_key, created


def main() -> None:
    args = parse_args()
    repo = Path(args.repo).resolve() if args.repo else Path.cwd()

    config = load_config()
    roadmap_path = find_roadmap(repo)
    epic, stories = generate_tickets(roadmap_path, repo)
    epic_key, created = push_to_jira(config, epic, stories)
    shutil.rmtree(repo / "tickets")

    story_keys = [key for _, key in created]
    story_range = f"{story_keys[0]}..{story_keys[-1]}" if len(story_keys) > 1 else story_keys[0]
    print(f"\nDone. Created {epic_key} with {len(story_keys)} stories: {story_range}")


if __name__ == "__main__":
    main()
